{
  "name": "byus",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": "24.x"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "@solana-program/memo": "0.10.0",
    "@solana-program/system": "0.10.0",
    "@solana-program/token": "0.9.0",
    "@solana/kit": "5.5.1"
  },
  "overrides": {
    "next": {
      "sharp": "0.35.3"
    },
    "@coinbase/cdp-sdk": {
      "axios": "1.18.1"
    },
    "ws@>=8.0.0 <8.21.0": "8.21.1"
  },
  "scripts": {
    "dev": "npm run dev --workspace @byus/web",
    "build": "npm run build --workspace @byus/web",
    "test": "npm run test --workspaces --if-present",
    "test:web": "npm run test --workspace @byus/web",
    "test:e2e": "npm run test:e2e --workspace @byus/web",
    "typecheck": "npm run typecheck --workspace @byus/web",
    "lint": "eslint apps/web apps/worker scripts --max-warnings=0",
    "lint:web": "eslint apps/web --max-warnings=0",
    "lint:worker": "eslint apps/worker --max-warnings=0",
    "security:audit": "npm audit --omit=dev",
    "security:tree": "npm ls @aws-sdk/client-secrets-manager fast-xml-parser axios ws postcss uuid --all",
    "security:verify": "node scripts/verify-security-dependencies.mjs",
    "security:ws-canary": "node scripts/verify-websocket-canary.mjs"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10"
  }
}
